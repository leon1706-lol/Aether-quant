# Copy this file to .env.live (untracked, .gitignore'd) and fill in real
# values before switching phase_v2.runtime.mode to "live" (V2-22). Never
# commit .env.live.
#
# Two consumers read these AETHER_* vars:
#  1. execution/live_credentials_io.py - a pre-flight credential-presence check.
#  2. scripts/render_lean_credentials.py (`aq render-lean-config`) - renders a
#     gitignored lean.live.json with these values overlaid onto the empty,
#     tracked lean.json template, which live/paper deployment then uses via
#     `--lean-config lean.live.json`. Lean does NOT expand env vars out of
#     lean.json itself, which is why this render step exists (the tracked
#     lean.json stays all-empty so it is safe to share; see
#     development/infrastructure.md's "Live Deployment Betreiben (V2-22)"
#     runbook and execution/lean_config_render.py).

# --- Interactive Brokers live credentials ---
AETHER_IB_ACCOUNT=
AETHER_IB_USER_NAME=
AETHER_IB_PASSWORD=
AETHER_IB_TRADING_MODE=paper

# --- Live market-data provider keys (only the one you actually use) ---
# Populate whichever feed lean.json's live-paper/live environment is configured
# for; leave the rest blank. These render into lean.json's matching fields.
AETHER_POLYGON_API_KEY=
AETHER_IEX_CLOUD_API_KEY=

# --- Database password for live deployments ---
# The default 'aether_dev_password' is fine for local dev but is published in
# the repo. Live mode refuses to start while the Postgres DSN still uses that
# default (execution/live_credentials.py::postgres_dsn_is_live_safe). Set a real
# one here (and in .env / .env.compose) before going live.
POSTGRES_PASSWORD=
