.env
.env.*
ib_config.py
*_config.local.py
config.json
config.local.json
lean.json
lean.local.json

*.key
*.pem

# OS/editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/

# Lean market data: too large for a public GitHub repo
data/**
!data/**/
