    "phase3": {
        "model": {
            "type": "robust_mlp_classifier",
            "hidden_layers": [
                64,
                32
            ],
            "dropout": 0.15,
            "activation": "relu",
            "normalization": "layernorm",
            "output_activation": "sigmoid",
            "use_asset_context": true
        },
        "training": {
            "seed": 42,
            "epochs": 120,
            "batch_size": 64,
            "learning_rate": 0.0007,
            "weight_decay": 0.0001,
            "patience": 18,
            "decision_threshold": 0.5,
            "optimize_threshold_metric": "mcc",
            "threshold_search_min": 0.35,
            "threshold_search_max": 0.65,
            "threshold_search_steps": 61
        }
    },
    "phase5": {
        "backtest": {
            "trading_days_per_year": 252,
            "strategy_mode": "long_flat",
            "buy_threshold_offset": 0.01,
            "sell_threshold_offset": 0.01
        }
    },
    "phase6": {
        "risk": {
